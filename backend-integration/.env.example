# Copie para ".env" (nunca commitar o .env real) e preencha com os valores obtidos
# nos portais de desenvolvedores do Inter e do Santander.

PORT=3000

# Origem autorizada a chamar este backend (o site publicado no GitHub Pages)
ALLOWED_ORIGIN=https://eduardosaarcaetano-ui.github.io

# --- Banco Inter ---
# Certificado cliente (mTLS) e chave, baixados no portal do desenvolvedor Inter.
# Guarde os arquivos .crt/.key fora do repositório e aponte o caminho absoluto aqui.
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
INTER_CERT_PATH=
INTER_KEY_PATH=
INTER_CONTA_CORRENTE=

# --- Santander ---
SANTANDER_CLIENT_ID=
SANTANDER_CLIENT_SECRET=
SANTANDER_WORKSPACE_ID=
