# Copie este arquivo para ".env" e preencha com os dados reais.
# Nunca envie o .env, certificados ou chaves privadas para o GitHub.

PORT=8787

# Separe por virgula se quiser liberar mais origens.
# Para teste local abrindo index.html pelo navegador, mantenha "null".
ALLOWED_ORIGINS=https://eduardosaarcaetano-ui.github.io,null,http://localhost,http://127.0.0.1

# Banco Inter
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=

# Use certificado + chave separados:
INTER_CERT_PATH=C:\caminho\seguro\inter.crt
INTER_KEY_PATH=C:\caminho\seguro\inter.key

# Ou use PFX/P12 no lugar dos dois campos acima:
INTER_PFX_PATH=
INTER_CERT_PASSPHRASE=

# Opcional: cadeia/CA fornecida pelo banco, quando houver.
INTER_CA_PATH=

# Conta corrente usada no header x-conta-corrente.
# Se deixar vazio, o backend usa o accountId enviado pelo ERP.
INTER_CONTA_CORRENTE=

# Normalmente nao precisa alterar.
INTER_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_TOKEN_PATH=/oauth/v2/token
INTER_EXTRATO_PATH=/banking/v2/extrato
INTER_SALDO_PATH=/banking/v2/saldo
INTER_SCOPE=extrato.read
INTER_REJECT_UNAUTHORIZED=true

# Investimentos Inter
# Se sua API tiver endpoint de investimentos liberado, informe o path aqui.
# Se ainda nao tiver, preencha o valor manual para aparecer no ERP.
INTER_INVESTMENTS_PATH=
INTER_INVESTMENT_BALANCE=
INTER_INVESTMENT_BALANCE_DATE=
